title: "TurboQuant KV-Cache"
message: "If you use this repository, please cite both this software and the original TurboQuant paper."
type: software
authors:
  - family-names: "2023"
    given-names: "Anita"
repository-code: "https://github.com/2023Anita/turboquant-kvcache"
